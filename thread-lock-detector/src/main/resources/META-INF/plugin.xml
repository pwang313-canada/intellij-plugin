<!-- src/main/resources/META-INF/plugin.xml -->
<idea-plugin>
    <id>com.cakk.threadlockchecker</id>
    <name>Thread Lock Detector</name>
    <version>1.0</version>
    <vendor email="your@email.com">Cakk</vendor>



    <!-- Actions -->
    <actions>
        <!-- Create a group that contains a separator and your action -->
        <group id="ThreadLockStaticGroup">
            <separator/>
            <action id="AnalyzeStaticThreadLocksAction"
                    class="org.cakk.threadlock.actions.AnalyzeStaticThreadLocksAction"
                    text="Analyze Static Thread Lock"
                    description="Check static thread lock issues in the selected file or folder"/>
            <!-- Add this group to the Analyze menu -->
            <add-to-group group-id="AnalyzeMenu" anchor="last"/>
        </group>
        <group id="ThreadLockRuntimeGroup">
            <separator/>
            <action id="AnalyzeRuntimeThreadLocksAction"
                    class="org.cakk.threadlock.actions.AnalyzeRuntimeThreadLocksAction"
                    text="Analyze Runtime Thread Lock"
                    description="Check runtime thread lock issues in the selected file or folder"/>
            <!-- Add this group to the Analyze menu -->
            <!--
            <add-to-group group-id="AnalyzeMenu" anchor="last"/>
            -->
        </group>
    </actions>

    <!-- Optional: Java inspection for thread locks -->
    <!-- Tool window registration -->
    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                id="Thread Lock Detector"
                anchor="bottom"
                factoryClass="org.cakk.threadlock.ui.ThreadLockToolWindowFactory"
                canCloseContents="true"/>

        <projectService serviceImplementation="org.cakk.threadlock.services.RemoteDeadlockMonitorService"/>
        <notificationGroup id="Deadlock Detector" displayType="BALLOON" isLogByDefault="true"/>
    </extensions>
    <!--
    <extensions defaultExtensionNs="com.intellij">
        <localInspection
                language="JAVA"
                groupPath="Java|Threading"
                groupName="Thread Locks"
                shortName="DangerousLockUsage"
                displayName="Dangerous thread lock / synchronization usage"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="org.cakk.threadlock.actions.DangerousLockInspection"/>
    </extensions>
    -->
    <extensions defaultExtensionNs="com.intellij">
        <!-- ... existing extensions ... -->
        <projectService serviceImplementation="org.cakk.threadlock.services.RemoteDeadlockMonitorService"/>
        <notificationGroup id="Deadlock Detector" displayType="BALLOON" isLogByDefault="true"/>
    </extensions>
</idea-plugin>