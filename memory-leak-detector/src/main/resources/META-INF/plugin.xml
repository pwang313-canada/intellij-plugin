<idea-plugin>
    <id>org.cakk.memory-leak-detector</id>
    <name>Memory Leak Detector</name>
    <version>1.0.0</version>
    <vendor email="pwang313@gmail.com" url="https://cakk.org">Cakk TechSoft Inc.</vendor>

    <description><![CDATA[
        <h2>Real-time Memory Leak Detection for IntelliJ IDEA</h2>
        <p>Monitor JVM memory usage and detect potential memory leaks in your application.</p>

            <h3>📸 Screenshots</h3>
            <div style="display: flex; flex-wrap: wrap; gap: 20px; justify-content: center; margin: 20px 0;">
                <div style="text-align: center; flex: 1; min-width: 300px;">
                    <img src="/images/memory-leak-confirm.png"
                         alt="Main Monitoring Window"
                         width="100%"
                         style="border: 1px solid #ccc; border-radius: 4px;"/>
                    <p><em>Real-time memory monitoring with toggleable metrics</em></p>
                </div>
                <div style="text-align: center; flex: 1; min-width: 300px;">
                    <img src="https://github.com/pwang313-canada/intellij-property/blob/main/src/main/resources/images/how-to-use.png"
                         alt="Memory Leak Alert"
                         width="100%"
                         style="border: 1px solid #ccc; border-radius: 4px;"/>
                    <p><em>Automatic alert when memory leak is detected</em></p>
                </div>
            </div>

        <h3>Features:</h3>
        <ul>
            <li><b>Real-time Monitoring</b> - Watch heap and old generation memory usage in real-time</li>
            <li><b>Interactive Chart</b> - Visual representation of memory usage over time</li>
            <li><b>Automatic Leak Detection</b> - Detects rapid memory growth patterns</li>
            <li><b>GC Analysis</b> - Tracks GC events and efficiency metrics</li>
            <li><b>User Confirmation</b> - Prompts user before invoking System.gc()</li>
            <li><b>Leak Simulation</b> - Built-in simulation to test detection</li>
            <li><b>Configurable Thresholds</b> - Customize detection sensitivity</li>
            <li><b>Detailed Logging</b> - Complete history of GC events and alerts</li>
            <li><b>File/Line Detection</b> - Pinpoints exact source code locations of memory leaks</li>
        </ul>

        <h3>How to Use:</h3>
        <ol>
            <li>Open <b>View → Tool Windows → Memory Monitor</b></li>
            <li>Click <b>Start Monitoring</b> to begin tracking memory usage</li>
            <li>Watch the chart and statistics for unusual growth patterns</li>
            <li>When rapid growth is detected, the exact file and line will be shown</li>
            <li>Use <b>Simulate Leak</b> to test the detection system</li>
            <li>Use <b>Find Leaks</b> to analyze current memory usage</li>
        </ol>

        <h3>Detection Thresholds:</h3>
        <ul>
            <li><b>Rapid Growth:</b> >10% growth per interval</li>
            <li><b>Warning:</b> >20% growth from baseline with low GC efficiency</li>
            <li><b>High Risk:</b> >50% growth with very poor GC efficiency</li>
            <li><b>Critical:</b> Old gen increasing after each GC cycle</li>
        </ul>

        <p>Configure thresholds in <b>Settings → Tools → Memory Leak Detector</b></p>
    ]]></description>

    <change-notes><![CDATA[
        <h3>Version 1.0.0 (Initial Release)</h3>
        <ul>
            <li>Initial release of Memory Leak Detector</li>
            <li>Real-time heap and old generation monitoring</li>
            <li>Automatic leak detection with multiple severity levels</li>
            <li>Interactive GC confirmation dialog</li>
            <li>Memory chart with zoom capability</li>
            <li>GC event tracking and efficiency analysis</li>
            <li>Leak simulation for testing</li>
            <li>Configurable detection thresholds</li>
            <li>Tool window with statistics panel and log viewer</li>
            <li>Keyboard shortcuts (Ctrl+Alt+M to start monitoring)</li>
            <li><b>NEW:</b> File and line number leak detection</li>
            <li><b>NEW:</b> Allocation tracking and survivor analysis</li>
        </ul>

        <h3>Known Issues</h3>
        <ul>
            <li>First GC after baseline may show negative efficiency (normal)</li>
            <li>Some GC events may be duplicated in log</li>
        </ul>

        <h3>Planned Features</h3>
        <ul>
            <li>Heap dump analysis on leak detection</li>
            <li>Export memory data to CSV</li>
            <li>Email notifications for critical alerts</li>
            <li>Integration with IntelliJ Profiler</li>
        </ul>
    ]]></change-notes>

    <idea-version since-build="233" until-build="242.*"/>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Tool Window -->
        <toolWindow id="Memory Monitor"
                    factoryClass="org.cakk.memoryleak.ui.MemoryMonitorToolWindowFactory"
                    anchor="bottom"
                    icon="AllIcons.Debugger.MemoryView"
                    canCloseContents="false"/>

        <!-- Services - Register all services here -->
        <projectService serviceImplementation="org.cakk.memoryleak.services.MemoryMonitorService"/>
        <projectService serviceImplementation="org.cakk.memoryleak.services.LeakDetectionService"/>
        <projectService serviceImplementation="org.cakk.memoryleak.services.AllocationInterceptor"/>
        <projectService serviceImplementation="org.cakk.memoryleak.settings.MemoryLeakSettings"/>

        <!-- Settings Page -->
        <projectConfigurable instance="org.cakk.memoryleak.ui.MemoryLeakSettingsConfigurable"
                             id="org.cakk.memoryleak.settings"
                             displayName="Memory Leak Detector"
                             parentId="tools"/>

        <!-- Notifications -->
        <notificationGroup id="Memory Leak Detector"
                           displayType="BALLOON"
                           isLogByDefault="true"/>
    </extensions>

    <actions>
        <!-- Start Monitoring Action -->
        <action id="MemoryLeakDetector.StartMonitoring"
                class="org.cakk.memoryleak.actions.StartDetectionAction"
                text="Start Memory Monitoring"
                description="Start monitoring memory usage for leaks"
                icon="AllIcons.Actions.Execute">
            <add-to-group group-id="ToolsMenu" anchor="first"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt M"/>
        </action>

        <!-- Stop Monitoring Action -->
        <action id="MemoryLeakDetector.StopMonitoring"
                class="org.cakk.memoryleak.actions.StopDetectionAction"
                text="Stop Memory Monitoring"
                description="Stop memory monitoring"
                icon="AllIcons.Actions.Suspend">
            <add-to-group group-id="ToolsMenu" anchor="first"/>
        </action>

        <!-- Simulate Leak Action -->
        <action id="MemoryLeakDetector.SimulateLeak"
                class="org.cakk.memoryleak.actions.SimulateLeakAction"
                text="Simulate Memory Leak"
                description="Run a memory leak simulation to test detection"
                icon="AllIcons.General.Warning">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>

        <!-- Find Leaks Action - NEW -->
        <action id="MemoryLeakDetector.FindLeaks"
                class="org.cakk.memoryleak.actions.FindLeaksAction"
                text="Find Memory Leaks"
                description="Analyze current memory usage and find potential leaks"
                icon="AllIcons.Actions.Find">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt L"/>
        </action>

        <!-- Force GC Action -->
        <action id="MemoryLeakDetector.ForceGC"
                class="org.cakk.memoryleak.actions.ForceGCAction"
                text="Force Garbage Collection"
                description="Request JVM to run garbage collection"
                icon="AllIcons.Actions.GC">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <!-- Toggle Monitoring Action -->
        <action id="MemoryLeakDetector.ToggleMonitoring"
                class="org.cakk.memoryleak.actions.ToggleMonitoringAction"
                text="Toggle Memory Monitoring"
                description="Start or stop memory monitoring">
            <add-to-group group-id="ToolsMenu" anchor="first"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift M"/>
        </action>

        <!-- Remote Monitoring Actions -->
        <action id="MemoryLeakDetector.ConnectRemote"
                class="org.cakk.memoryleak.actions.ConnectToRemoteAction"
                text="Connect to Remote Process"
                description="Connect to a running Java application to monitor its memory"
                icon="AllIcons.General.Web">
            <add-to-group group-id="ToolsMenu" anchor="first"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt R"/>
        </action>
        <!-- Disconnect Action -->
        <action id="MemoryLeakDetector.Disconnect"
                class="org.cakk.memoryleak.actions.DisconnectAction"
                text="Disconnect"
                description="Disconnect from remote process"
                icon="AllIcons.Actions.Cancel">
            <add-to-group group-id="ToolsMenu" anchor="first"/>
        </action>

        <action id="MemoryLeakDetector.CheckLeaks"
                class="org.cakk.memoryleak.actions.CheckMemoryLeaksAction"
                text="Check Memory Leaks"
                description="Check for memory leaks with GC analysis"
                icon="AllIcons.Actions.Check">
            <add-to-group group-id="ToolsMenu" anchor="first"/>
        </action>
        <action id="MemoryLeakDetector.AnalyzeAfterGC"
                class="org.cakk.memoryleak.actions.AnalyzeAfterGCAction"
                text="Analyze Memory After GC"
                description="Analyze memory leaks when GC doesn't reduce heap size"
                icon="AllIcons.Actions.Analyze">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt G"/>
        </action>
        <action id="MemoryLeakDetector.DetailedGCAnalysis"
                class="org.cakk.memoryleak.actions.DetailedGCAnalysisAction"
                text="Detailed GC Analysis"
                description="Detailed analysis of GC effectiveness and memory leak detection"
                icon="AllIcons.Actions.Analyze">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt D"/>
        </action>

        <action id="MemoryLeakDetector.DisconnectRemote"
                class="org.cakk.memoryleak.actions.DisconnectFromRemoteAction"
                text="Disconnect from Remote"
                description="Disconnect from remote process"
                icon="AllIcons.Actions.Cancel">
            <add-to-group group-id="ToolsMenu" anchor="first"/>
        </action>

        <action id="MemoryLeakDetector.AnalyzeRemoteLeak"
                class="org.cakk.memoryleak.actions.AnalyzeAfterGCAction"
                text="Analyze Remote Memory Leak"
                description="Analyze memory leak in remote process"
                icon="AllIcons.Actions.Analyze">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="MemoryLeakDetector.LocalLeakTest"
                class="org.cakk.memoryleak.actions.LocalLeakTestAction"
                text="Test Local Memory Leak"
                description="Test memory leak detection with exact file and line tracking"
                icon="AllIcons.General.Warning">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>

    <projectListeners>
        <listener class="org.cakk.memoryleak.listeners.ProjectCloseListener"
                  topic="com.intellij.openapi.project.ProjectManagerListener"/>
    </projectListeners>

    <applicationListeners>
        <listener class="org.cakk.memoryleak.listeners.ApplicationCloseListener"
                  topic="com.intellij.ide.AppLifecycleListener"/>
    </applicationListeners>
</idea-plugin>