<idea-plugin>

    <id>org.cakk.propertytool</id>
    <name>Property Tool</name>
    <vendor email="pwang313@gmail.com">Example</vendor>

    <actions>

        <group id="PropertyTool.Group"
               text="Property Tool"
               description="Tools for YAML and Properties"
               popup="true">

            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>

            <action id="PropertyTool.ConvertYaml"
                    class="org.cakk.property.action.ConvertYamlToPropertiesAction"
                    text="Convert YAML → Properties"
                    description="Convert YAML to Properties file"/>
            <action id="PropertyTool.ConvertProperties"
                    class="org.cakk.property.action.ConvertPropertiesToYamlAction"
                    text="Convert Properties → YAML"
                    description="Convert Properties to YAML file"/>
            <separator/>
            <action id="org.cakk.property.action.MergePropertiesAction"
                    class="org.cakk.property.action.MergePropertiesAction"
                    text="Merge and Clean Properties Files"
                    description="Merge all properties files and move common properties to application.properties"/>
        </group>

    </actions>

</idea-plugin>